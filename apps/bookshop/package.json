{
  "name": "@pnpm-bookshop/bookshop",
  "version": "1.0.0",
  "description": "CAP Bookshop Sample Application",
  "private": true,
  "license": "ISC",
  "scripts": {
    "start": "cds-serve",
    "watch": "cds watch",
    "watch-managebooks": "cds watch --open com.alliander.ui.managebooks/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "dependencies": {
    "@sap/cds": "^8",
    "@sap/xssec": "^4",
    "@cap-js/hana": "^1",
    "express": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^1",
    "@sap/cds-dk": "^8",
    "cds-plugin-ui5": "^0.13.0"
  },
  "cds": {
    "[production]": {
      "requires": {
        "db": "hana",
        "auth": "xsuaa"
      }
    },
    "build": {
      "target": "gen",
      "tasks": [
        {
          "for": "hana",
          "src": "db",
          "options": {
            "model": [
              "db",
              "srv"
            ]
          }
        },
        {
          "for": "node-cf",
          "src": "srv",
          "options": {
            "model": [
              "db",
              "srv"
            ]
          }
        }
      ]
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/managebooks"
  ]
}
